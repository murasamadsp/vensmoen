{
  "name": "vensmoen",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Flerspråklig informasjonsside for Vensmoen mottak",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "validate:i18n": "node scripts/validate-i18n.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check": "npm run validate:i18n && npm run typecheck && npm run lint",
    "lint": "biome check",
    "lint:write": "biome check --write",
    "sync:i18n": "node scripts/sync-i18n.mjs && biome check --write src/i18n",
    "gen:cms": "node scripts/gen-cms-config.mjs && biome check --write public/admin/config.generated.json"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.7",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.4.15",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.9.3"
  }
}
