#!/bin/sh
# Pre-commit hook: biome lint check
# Встановлюється через: npm run setup
# Або вручну: cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

printf "⚙  biome check..."
npx biome check --no-errors-on-unmatched 2>&1
EXIT=$?

if [ $EXIT -ne 0 ]; then
  printf "\n❌  Biome знайшов помилки. Виправ або запусти:\n"
  printf "     npm run lint:write   # авто-виправлення\n"
  printf "     npm run lint         # лише перевірка\n"
  exit 1
fi

printf " ✓\n"
exit 0
