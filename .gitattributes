# Автовизначення текстових файлів, нормалізація LF
* text=auto

# Shell — примусово LF
*.sh text eol=lf

# Текстові формати
*.astro text
*.ts text
*.css text
*.js text
*.mjs text
*.json text
*.yml text
*.yaml text
*.md text
*.svg text
*.env text
.env.example text eol=lf

# Бінарні
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.pdf binary

# Linguist
*.astro linguist-language=Astro
