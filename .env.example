# Скопіюйте цей файл у .env для локальних запусків. .env не комітити.

# Провайдер: anthropic | deepseek | google
TRANSLATE_PROVIDER=anthropic

# Модель основного провайдера.
# Anthropic: claude-sonnet-4-6
# DeepSeek: deepseek-v4-flash або deepseek-v4-pro
# Google Translate: nmt
TRANSLATE_MODEL=claude-sonnet-4-6

# Резерв: можна вказати іншу модель того самого провайдера або інший провайдер.
# Якщо TRANSLATE_FALLBACK_PROVIDER порожній, fallback іде в TRANSLATE_PROVIDER.
TRANSLATE_FALLBACK_PROVIDER=
TRANSLATE_FALLBACK_MODEL=

# Джерело правди для CMS-режиму.
TRANSLATE_SOURCE_LOCALE=nb
TRANSLATE_STRICT_SOURCE=1

# Мережеві edge cases.
TRANSLATE_TIMEOUT_MS=60000
TRANSLATE_RETRIES=2

# Перевірка живості провайдера/моделі:
# npm run translate:health

# API keys. Заповніть тільки ті, які реально використовуються.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
