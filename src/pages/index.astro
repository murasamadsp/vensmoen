---
import { defaultLocale, localeCodes } from '../i18n/locales';

const base = import.meta.env.BASE_URL;
const target = `${base}${defaultLocale}/`;
---

<!doctype html>
<html lang="nb" data-base={base} data-locs={localeCodes.join(',')}>
  <head>
    <meta charset="utf-8" />
    <!-- Kjører under parsing, FØR body males → ingen synlig mellomside.
         Velger språk fra nettleseren, faller tilbake til nb. -->
    <script is:inline>
      (function () {
        var el = document.documentElement;
        var base = el.dataset.base;
        var locs = el.dataset.locs.split(',');
        var lang = (navigator.language || 'nb').slice(0, 2).toLowerCase();
        var to = base + (locs.indexOf(lang) > -1 ? lang : 'nb') + '/';
        location.replace(to);
      })();
    </script>
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Kildesortering</title>
  </head>
  <body>
    <noscript>
      <a href={target}>Kildesortering &rarr;</a>
    </noscript>
  </body>
</html>
