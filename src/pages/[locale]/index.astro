---
import LanguagePicker from '../../components/LanguagePicker.astro';
import SectionIcon from '../../components/SectionIcon.astro';
import { dutyPhone, emergencyNumbers } from '../../data/emergency';
import { localeCodes } from '../../i18n/locales';
import {
  localeAbout,
  localeGuide,
  localeRules,
  localeWaste,
} from '../../i18n/paths';
import { getStrings } from '../../i18n/strings';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return localeCodes.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!locale) throw new Error('locale route param is required');
const t = getStrings(locale);
const site = t.site;

// Головна – це хаб: чотири секційні картки. Гід із сортування перевикористовує
// свої наявні переклади (ui.siteTitle/tagline) як текст картки.
const cards = [
  {
    key: 'about',
    href: localeAbout(locale),
    title: t.pages.about.title,
    desc: t.pages.about.cardDesc,
  },
  {
    key: 'rules',
    href: localeRules(locale),
    title: t.pages.rules.title,
    desc: t.pages.rules.cardDesc,
  },
  {
    key: 'guide',
    href: localeGuide(locale),
    title: t.pages.guide.title,
    desc: t.pages.guide.cardDesc,
  },
  {
    key: 'waste',
    href: localeWaste(locale),
    title: t.ui.siteTitle,
    desc: t.ui.tagline,
  },
] as const;

const emergencyLabels: Record<string, string> = {
  fire: site.emergencyFire,
  police: site.emergencyPolice,
  ambulance: site.emergencyAmbulance,
  doctor: site.emergencyDoctor,
};
---

<BaseLayout locale={locale} title={site.title} description={site.description}>
  <a class="skip-link" href="#main">{t.ui.skipToContent}</a>

  <header class="site-header">
    <div class="wrap site-header__bar site-header__bar--quiz">
      <div class="brand">
        <!-- На главной бренд не дублируется в шапке -->
      </div>
      <div class="site-header__tools">
        <LanguagePicker current={locale} label={t.ui.languagePicker} />
      </div>
    </div>
  </header>

  <main id="main" class="wrap">
    <section class="hub-hero">
      <p class="hub-hero__tagline">{site.tagline}</p>
      <h1 class="page-title">{site.name}</h1>
      <p class="lede">{site.intro}</p>
    </section>

    <nav class="hub" aria-label={site.sectionsLabel}>
      {
        cards.map((card) => (
          <a class={`hub-card hub-card--${card.key}`} href={card.href}>
            <SectionIcon section={card.key} />
            <span class="hub-card__text">
              <span class="hub-card__title">{card.title}</span>
              <span class="hub-card__desc">{card.desc}</span>
            </span>
            <span class="hub-card__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14" /><path d="m13 6 6 6-6 6" />
              </svg>
            </span>
          </a>
        ))
      }
    </nav>

    {/* Черговий телефон – між розділами та екстреними номерами: помітно, але не плутається з 110/112/113 */}
    <section class="duty" aria-labelledby="duty-title">
      <div class="duty__body">
        <h2 id="duty-title" class="duty__title">{site.dutyTitle}</h2>
        <p class="duty__text">{site.dutyText}</p>
      </div>
      <a class="duty__phone" href={`tel:${dutyPhone.tel}`}>{dutyPhone.display}</a>
    </section>

    <section class="emg" aria-labelledby="emg-title">
      <h2 id="emg-title" class="emg__title">{site.emergencyTitle}</h2>
      <p class="emg__note">{site.emergencyNote}</p>
      <ul class="emg__list" role="list">
        {
          emergencyNumbers.map((n) => (
            <li class={`emg__item emg__item--${n.id}`}>
              <a class="emg__link" href={`tel:${n.tel}`}>
                <span class="emg__num">{n.display}</span>
                <span class="emg__label">{emergencyLabels[n.id]}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>{site.name} · {site.tagline}</p>
    </div>
  </footer>
</BaseLayout>
