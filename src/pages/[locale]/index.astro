---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LanguagePicker from '../../components/LanguagePicker.astro';
import GuideBody from '../../components/GuideBody.astro';
import { localeCodes } from '../../i18n/locales';
import { getStrings } from '../../i18n/strings';
import { localePrint, localeQuiz } from '../../i18n/paths';

export function getStaticPaths() {
  return localeCodes.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const t = getStrings(locale);
const ui = t.ui;
---

<BaseLayout
  locale={locale}
  title={`${t.meta.title} · Iris Salten`}
  description={t.meta.description}
>
  <a class="skip-link" href="#main">{ui.skipToContent}</a>

  <header class="site-header">
    <div class="wrap site-header__bar">
      <LanguagePicker current={locale} label={ui.languagePicker} />
      <div class="site-header__tools">
        <a class="btn btn--ghost" href={localeQuiz(locale)}>{ui.quizNav}</a>
        <a class="btn" href={localePrint(locale)}>{ui.print}</a>
      </div>
    </div>
  </header>

  <main id="main" class="wrap">
    <GuideBody t={t} />
  </main>
</BaseLayout>
