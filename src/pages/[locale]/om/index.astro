---
import InfoPage from '../../../components/InfoPage.astro';
import { mapLinks } from '../../../data/location';
import { transportApps } from '../../../data/transport';
import { localeCodes } from '../../../i18n/locales';
import { getStrings } from '../../../i18n/strings';

export function getStaticPaths() {
  return localeCodes.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!locale) throw new Error('locale route param is required');
const t = getStrings(locale);
const om = t.pages.om;
---

<InfoPage locale={locale} pageKey="om">
  <section class="info-block" aria-labelledby="contacts-title">
    <h2 id="contacts-title" class="info-block__heading">{om.contactsTitle}</h2>
    <p class="info-block__body contacts-intro">{om.contactsIntro}</p>
    <ul class="contacts" role="list">
      {
        om.contacts.map((contact) => (
          <li class="contact-card">
            <h3 class="contact-card__role">{contact.role}</h3>
            <p class="contact-card__desc">{contact.desc}</p>
            <a class="contact-card__email" href={`mailto:${contact.email}`}>
              <svg
                class="contact-card__icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="m2 7 10 6 10-6" />
              </svg>
              <span>{contact.email}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="info-block" aria-labelledby="map-title">
    <h2 id="map-title" class="info-block__heading">{t.site.mapTitle}</h2>
    <div class="map-links">
      {
        mapLinks.map((link) => (
          <a
            class="btn btn--ghost"
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-describedby="newtab-note"
          >
            {link.name}
          </a>
        ))
      }
    </div>
    <span id="newtab-note" class="sr-only">{t.ui.opensInNewTab}</span>
  </section>

  <section class="info-block" aria-labelledby="transport-title">
    <h2 id="transport-title" class="info-block__heading">{om.transportTitle}</h2>
    <p class="info-block__body contacts-intro">{om.transportIntro}</p>
    <div class="map-links">
      {
        transportApps.map((app) => (
          <a
            class="btn btn--ghost"
            href={app.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-describedby="newtab-note"
          >
            {app.name}
          </a>
        ))
      }
    </div>
  </section>
</InfoPage>
