---
import QRCode from 'qrcode';
import GuideBody from '../../../../components/GuideBody.astro';
import { localeCodes } from '../../../../i18n/locales';
import { localeWaste, siteUrl } from '../../../../i18n/paths';
import { getStrings } from '../../../../i18n/strings';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/print.css';

export function getStaticPaths() {
  return localeCodes.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!locale) throw new Error('locale route param is required');
const t = getStrings(locale);
const ui = t.ui;

// QR генерується під час build – без runtime-JS і без зовнішнього сервісу.
const qrSvg = await QRCode.toString(siteUrl(locale), {
  type: 'svg',
  margin: 0,
  color: { dark: '#111111', light: '#ffffff00' },
});
---

<BaseLayout
  locale={locale}
  title={`${ui.siteTitle} – ${ui.print}`}
  description={ui.tagline}
  bodyClass="print-page"
  noindex={true}
>
  <a class="skip-link" href="#main">{ui.skipToContent}</a>

  <div class="no-print">
    <a class="btn btn--ghost" href={localeWaste(locale)}>{ui.backToGuide}</a>
    <button class="btn" type="button" id="printBtn">{ui.print}</button>
  </div>

  <main id="main">
    <article class="print-doc">
      <GuideBody t={t} qrSvg={qrSvg} />
    </article>
  </main>

  <script is:inline>
    (function () {
      var doc = document.querySelector('.print-doc');

      // Вимірює A4-висоту з точністю поточного DPI.
      function a4px() {
        var m = document.createElement('div');
        m.style.cssText = 'height:297mm;position:absolute;visibility:hidden';
        document.body.appendChild(m);
        var h = m.offsetHeight;
        m.remove();
        return h;
      }

      // Масштабує вниз (ніколи вгору), щоб контент завжди був рівно однією
      // A4-сторінкою, незалежно від довжини мови.
      function fit() {
        if (!doc) return;
        doc.style.zoom = '1';
        var target = a4px();
        var actual = doc.scrollHeight;
        if (actual > target + 1) {
          doc.style.zoom = String(Math.max(0.6, target / actual));
        }
      }

      if (document.readyState === 'complete') fit();
      else window.addEventListener('load', fit);

      // Debounce: resize спрацьовує безперервно, а fit() робить три примусові
      // reflow за виклик (a4px-вимір + zoom-reset + scrollHeight).
      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(fit, 150);
      });
      window.addEventListener('beforeprint', fit);

      var btn = document.getElementById('printBtn');
      if (btn)
        btn.addEventListener('click', function () {
          fit();
          window.print();
        });
    })();
  </script>
</BaseLayout>
