---
import LanguagePicker from '../../../components/LanguagePicker.astro';
import SearchBar from '../../../components/SearchBar.astro';
import ModuleCard from '../../../components/ModuleCard.astro';
import { localeCodes } from '../../../i18n/locales';
import { localeHome } from '../../../i18n/paths';
import { getStrings } from '../../../i18n/strings';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ENABLED_MODULES, getModule } from '../../../data/modules';

export function getStaticPaths() {
  return localeCodes.flatMap((locale) =>
    ENABLED_MODULES.filter((m) => m.id !== 'fractions').map((mod) => ({
      params: { locale, module: mod.id },
    }))
  );
}

const { locale, module: moduleId } = Astro.params;
if (!locale || !moduleId) throw new Error('locale and module params are required');

const t = getStrings(locale);
const ui = t.ui;
const modConfig = getModule(moduleId);

if (!modConfig) {
  return Astro.redirect(`/${locale}/`);
}

// Get module title from UI translations
const moduleTitle = 
  moduleId === 'health' ? ui.moduleHealth :
  moduleId === 'legal' ? ui.moduleLegal :
  moduleId === 'education' ? ui.moduleEducation :
  moduleId === 'camp' ? ui.moduleCamp :
  moduleId;

// Placeholder content - AGENTS: This is where you add real content
const placeholderArticles = [
  {
    slug: 'getting-started',
    title: `Getting Started with ${moduleTitle}`,
    excerpt: 'Essential information to help you get started. Content will be added soon.',
    priority: 'high' as const,
  },
];
---

<BaseLayout
  locale={locale}
  title={`${moduleTitle} · ${ui.wikiHubTitle}`}
  description={`Information about ${moduleTitle.toLowerCase()} for refugees and newcomers.`}
>
  <a class="skip-link" href="#main">{ui.skipToContent}</a>

  <header class="site-header">
    <div class="wrap site-header__bar">
      <LanguagePicker current={locale} label={ui.languagePicker} />
      <div class="site-header__tools">
        <a class="btn btn--ghost" href={localeHome(locale)}>{ui.backToGuide}</a>
      </div>
    </div>
  </header>

  <main id="main" class="wrap module-page">
    <!-- Module Header -->
    <section class="module-hero" style={`--module-color: ${modConfig.color}`}>
      <div class="module-hero__icon" aria-hidden="true">{modConfig.icon}</div>
      <h1 class="module-title">{moduleTitle}</h1>
      <p class="module-subtitle">
        {moduleId === 'health' && 'Healthcare information, emergency numbers, and medical resources'}
        {moduleId === 'legal' && 'Legal rights, asylum process, and important documents'}
        {moduleId === 'education' && 'Schools, language courses, and educational opportunities'}
        {moduleId === 'camp' && 'Rules, facilities, and community guidelines'}
      </p>
      
      <SearchBar placeholder={ui.searchPlaceholder} moduleId={moduleId} />
    </section>

    <!-- Articles List -->
    <section class="module-content">
      <h2 class="sr-only">{ui.modules}</h2>
      
      <div class="articles-grid">
        {placeholderArticles.map((article) => (
          <article class="article-card" data-priority={article.priority}>
            <div class="article-card__header">
              {article.priority === 'urgent' && (
                <span class="article-badge article-badge--urgent">Urgent</span>
              )}
              {article.priority === 'high' && (
                <span class="article-badge article-badge--high">Important</span>
              )}
            </div>
            <h3 class="article-card__title">{article.title}</h3>
            <p class="article-card__excerpt">{article.excerpt}</p>
            <div class="article-card__footer">
              <span class="article-card__meta">
                {ui.lastUpdated}: TBD
              </span>
            </div>
          </article>
        ))}
      </div>

      <!-- Placeholder for FAQ section -->
      <section class="module-faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading">{ui.faqTitle}</h2>
        <div class="faq-placeholder">
          <p>Frequently asked questions about {moduleTitle.toLowerCase()} will be added here.</p>
          <p class="agent-note"><strong>Note for content agents:</strong> Add FAQ items in the i18n JSON files under `{moduleId}.faqs`</p>
        </div>
      </section>

      <!-- Resources section -->
      <section class="module-resources" aria-labelledby="resources-heading">
        <h2 id="resources-heading">{ui.resourcesTitle}</h2>
        <div class="resources-placeholder">
          <p>Useful links and resources will be listed here.</p>
          <p class="agent-note"><strong>Note for content agents:</strong> Add resources in the i18n JSON files or create a data file at <code>src/data/modules/{moduleId}.ts</code></p>
        </div>
      </section>
    </section>

    <!-- Other Modules Quick Nav -->
    <aside class="module-nav" aria-label={ui.modules}>
      <h2 class="module-nav__title">Explore other topics</h2>
      <div class="module-nav__grid">
        {
          ENABLED_MODULES
            .filter((m) => m.id !== moduleId && m.id !== 'fractions')
            .map((mod) => (
              <ModuleCard
                moduleId={mod.id}
                icon={mod.icon}
                color={mod.color}
                title={
                  mod.id === 'health' ? ui.moduleHealth :
                  mod.id === 'legal' ? ui.moduleLegal :
                  mod.id === 'education' ? ui.moduleEducation :
                  mod.id === 'camp' ? ui.moduleCamp :
                  mod.id
                }
                href={`/${locale}/${mod.id}/`}
              />
            ))
        }
      </div>
    </aside>
  </main>
</BaseLayout>

<style>
  .module-page {
    padding: 0;
  }

  /* Module Hero */
  .module-hero {
    background: linear-gradient(
      135deg,
      var(--module-color) 0%,
      color-mix(in oklch, var(--module-color), var(--color-bg) 60%) 100%
    );
    padding: var(--space-section) var(--space-4);
    text-align: center;
    color: white;
  }

  .module-hero__icon {
    font-size: 4rem;
    margin-bottom: var(--space-3);
  }

  .module-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.5rem + 3vw, 3rem);
    margin: 0 0 var(--space-2);
    letter-spacing: -0.02em;
  }

  .module-subtitle {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-4);
    opacity: 0.95;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  .module-hero .search-container {
    --search-bg: rgba(255, 255, 255, 0.95);
  }

  .module-hero .search-input {
    background: var(--search-bg);
    border-color: transparent;
  }

  /* Content Section */
  .module-content {
    padding: var(--space-section) var(--space-4);
    background: var(--color-bg);
  }

  .articles-grid {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
    max-width: var(--maxw);
    margin: 0 auto var(--space-section);
  }

  @media (min-width: 56rem) {
    .articles-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .article-card {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: var(--space-4);
    box-shadow: var(--shadow-card);
    transition: transform var(--duration) var(--ease),
                box-shadow var(--duration) var(--ease);
  }

  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lift);
  }

  .article-card__header {
    margin-bottom: var(--space-2);
  }

  .article-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
  }

  .article-badge--urgent {
    background: oklch(65% 0.2 25);
    color: white;
  }

  .article-badge--high {
    background: oklch(65% 0.15 35);
    color: white;
  }

  .article-card__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    margin: 0 0 var(--space-2);
    color: var(--color-ink);
  }

  .article-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin: 0 0 var(--space-3);
  }

  .article-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-line);
  }

  .article-card__meta {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
  }

  /* FAQ & Resources */
  .module-faq,
  .module-resources {
    max-width: var(--maxw);
    margin: 0 auto var(--space-section);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
  }

  .module-faq h2,
  .module-resources h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin: 0 0 var(--space-3);
  }

  .faq-placeholder,
  .resources-placeholder {
    color: var(--color-ink-soft);
  }

  .agent-note {
    margin-top: var(--space-3);
    padding: var(--space-3);
    background: color-mix(in oklch, var(--color-accent) 10%, var(--color-surface));
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
  }

  .agent-note code {
    background: var(--color-bg);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.9em;
  }

  /* Module Navigation */
  .module-nav {
    padding: var(--space-section) var(--space-4);
    background: var(--color-surface);
    border-top: 1px solid var(--color-line);
  }

  .module-nav__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    text-align: center;
    margin: 0 0 var(--space-4);
  }

  .module-nav__grid {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
    max-width: var(--maxw);
    margin: 0 auto;
  }

  @media (min-width: 56rem) {
    .module-nav__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 80rem) {
    .module-nav__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
