---
import { locales } from '../i18n/locales';
import { localeHome } from '../i18n/paths';

interface Props {
  current: string;
  label: string;
}
const { current, label } = Astro.props;
const cur = locales.find((l) => l.code === current) ?? locales[0];
---

<details class="langs">
  <summary class="langs__summary">
    <span class="langs__label">{label}</span>
    <span class="langs__current" lang={cur.htmlLang}>{cur.label}</span>
    <span class="langs__chev" aria-hidden="true"></span>
  </summary>
  <ul class="langs__menu">
    {
      locales.map((l) => (
        <li>
          <a
            href={localeHome(l.code)}
            lang={l.htmlLang}
            aria-current={l.code === current ? 'true' : undefined}
          >
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>
</details>

<script is:inline>
  // Ren progressiv forbedring – <details> fungerer fullt uten dette.
  // Lukker menyen ved Escape og klikk utenfor (vanlig meny-forventning).
  (function () {
    var d = document.currentScript.previousElementSibling;
    if (!d || d.tagName !== 'DETAILS') return;
    document.addEventListener('click', function (e) {
      if (d.open && !d.contains(e.target)) d.open = false;
    });
    d.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && d.open) {
        d.open = false;
        d.querySelector('summary').focus();
      }
    });
  })();
</script>
