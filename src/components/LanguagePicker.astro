---
import { locales } from '../i18n/locales';
import { localeHome } from '../i18n/paths';

interface Props {
  current: string;
  label: string;
}
const { current, label } = Astro.props;
---

<div class="langs">
  <label class="langs__label" for="lang-select">{label}</label>
  <select id="lang-select" class="langs__select" aria-label={label}>
    {
      locales.map((l) => (
        <option
          value={localeHome(l.code)}
          selected={l.code === current}
          lang={l.htmlLang}
        >
          {l.label}
        </option>
      ))
    }
  </select>
</div>

<script is:inline>
  (function () {
    var s = document.getElementById('lang-select');
    if (s)
      s.addEventListener('change', function () {
        if (s.value) location.href = s.value;
      });
  })();
</script>
