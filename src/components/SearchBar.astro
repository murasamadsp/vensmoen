/**
 * SearchBar Component
 * Client-side search for WikiHub content
 */

interface Props {
  placeholder: string;
  moduleId?: string;
}

const { placeholder, moduleId } = Astro.props;
---

<div class="search-container" data-module={moduleId ?? 'all'}>
  <div class="search-input-wrapper">
    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/>
      <path d="M21 21l-4.35-4.35"/>
    </svg>
    <input 
      type="search" 
      class="search-input" 
      placeholder={placeholder}
      aria-label={placeholder}
      data-search-input
    />
    <button class="search-clear" type="button" aria-label="Clear search" hidden data-search-clear>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <div class="search-results" data-search-results hidden></div>
</div>

<script>
  (function() {
    const container = document.querySelector('.search-container');
    if (!container) return;
    
    const input = container.querySelector('[data-search-input]');
    const clearBtn = container.querySelector('[data-search-clear]');
    const resultsBox = container.querySelector('[data-search-results]');
    
    if (!input || !resultsBox) return;
    
    // Simple client-side search - agents can enhance this
    let debounceTimer;
    
    input.addEventListener('input', function(e) {
      const query = e.target.value.trim().toLowerCase();
      
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() {
        if (query.length < 2) {
          resultsBox.hidden = true;
          resultsBox.innerHTML = '';
          if (clearBtn) clearBtn.hidden = true;
          return;
        }
        
        if (clearBtn) clearBtn.hidden = false;
        
        // Placeholder for search results
        // Agents: Implement actual search logic here
        // For now, just show a message
        resultsBox.innerHTML = '<p class="search-hint">Search functionality will be implemented with content</p>';
        resultsBox.hidden = false;
      }, 200);
    });
    
    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        input.value = '';
        resultsBox.hidden = true;
        resultsBox.innerHTML = '';
        clearBtn.hidden = true;
        input.focus();
      });
    }
    
    // Close on outside click
    document.addEventListener('click', function(e) {
      if (!container.contains(e.target)) {
        resultsBox.hidden = true;
      }
    });
  })();
</script>

<style>
  .search-container {
    position: relative;
    max-width: 600px;
    margin: 0 auto var(--space-4);
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: var(--space-3);
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-ink-soft);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: var(--space-3) var(--space-3) var(--space-3) calc(var(--space-3) + 1.75rem);
    font-size: var(--text-base);
    font-family: var(--font-body);
    background: var(--color-surface);
    border: 2px solid var(--color-line);
    border-radius: var(--radius);
    color: var(--color-ink);
    transition: border-color var(--duration) var(--ease),
                box-shadow var(--duration) var(--ease);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--color-accent) 20%, transparent);
  }

  .search-input::placeholder {
    color: var(--color-ink-soft);
  }

  .search-clear {
    position: absolute;
    right: var(--space-2);
    padding: var(--space-2);
    background: none;
    border: none;
    color: var(--color-ink-soft);
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color var(--duration) var(--ease),
                color var(--duration) var(--ease);
  }

  .search-clear:hover {
    background: var(--color-line);
    color: var(--color-ink);
  }

  .search-clear svg {
    width: 1rem;
    height: 1rem;
  }

  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lift);
    z-index: 100;
    max-height: 400px;
    overflow-y: auto;
  }

  .search-hint {
    padding: var(--space-3) var(--space-4);
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
    margin: 0;
  }

  /* RTL support */
  [dir="rtl"] .search-icon {
    left: auto;
    right: var(--space-3);
  }

  [dir="rtl"] .search-input {
    padding-left: var(--space-3);
    padding-right: calc(var(--space-3) + 1.75rem);
  }

  [dir="rtl"] .search-clear {
    right: auto;
    left: var(--space-2);
  }
</style>
