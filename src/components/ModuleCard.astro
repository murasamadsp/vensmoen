/**
 * ModuleCard Component
 * Displays a card for navigating to a module section
 */

interface Props {
  moduleId: string;
  icon: string;
  color: string;
  title: string;
  description?: string;
  href: string;
}

const { moduleId, icon, color, title, description, href } = Astro.props;
---

<a class="module-card" href={href} style={`--module-color: ${color}`}>
  <div class="module-card__icon" aria-hidden="true">{icon}</div>
  <div class="module-card__content">
    <h3 class="module-card__title">{title}</h3>
    {description && <p class="module-card__desc">{description}</p>}
  </div>
  <svg class="module-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M9 18l6-6-6-6"/>
  </svg>
</a>

<style>
  .module-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: var(--color-ink);
    transition: transform var(--duration) var(--ease), 
                box-shadow var(--duration) var(--ease),
                border-color var(--duration) var(--ease);
    position: relative;
    overflow: hidden;
  }

  .module-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 4px;
    background: var(--module-color);
    transition: width var(--duration) var(--ease);
  }

  .module-card:hover,
  .module-card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lift);
    border-color: var(--module-color);
    outline: none;
  }

  .module-card:hover::before,
  .module-card:focus-visible::before {
    width: 6px;
  }

  .module-card__icon {
    font-size: 2.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .module-card__content {
    flex: 1;
    min-width: 0;
  }

  .module-card__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    margin: 0 0 var(--space-1);
    color: var(--color-ink);
  }

  .module-card__desc {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    margin: 0;
    line-height: 1.5;
  }

  .module-card__arrow {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--color-ink-soft);
    transition: transform var(--duration) var(--ease),
                color var(--duration) var(--ease);
  }

  .module-card:hover .module-card__arrow,
  .module-card:focus-visible .module-card__arrow {
    transform: translateX(4px);
    color: var(--module-color);
  }

  @media (max-width: 768px) {
    .module-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .module-card__arrow {
      display: none;
    }

    .module-card::before {
      width: 100%;
      height: 4px;
      bottom: auto;
    }

    .module-card:hover::before,
    .module-card:focus-visible::before {
      width: 100%;
      height: 6px;
    }
  }
</style>
