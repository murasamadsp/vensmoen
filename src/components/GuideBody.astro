---
import { fractions } from '../data/fractions';
import type { Strings } from '../i18n/strings';
// Спільний контент для вебсторінки І друкованого аркуша. Структура однакова,
// візуально відрізняє лише CSS (екран проти A4).
import FractionCard from './FractionCard.astro';

interface Props {
  t: Strings;
  /** Задається лише на друкованому маршруті – QR-код показується тільки там. */
  qrSvg?: string;
}
const { t, qrSvg } = Astro.props;
const ui = t.ui;
const verified = fractions[0].lastVerified;
---

<div class="guide">
  <header class="guide__head">
    <div class="guide__lead">
      <h1 class="page-title">{ui.siteTitle}</h1>
      <p class="lede">{ui.intro}</p>
    </div>
    {
      qrSvg && (
        <div class="guide__qr">
          <div class="guide__qr-code" role="img" aria-label={ui.scanHint}>
            <Fragment set:html={qrSvg} />
          </div>
          <span aria-hidden="true">{ui.scanHint}</span>
        </div>
      )
    }
  </header>

  <div class="fractions">
    {
      fractions.map((f) => (
        <FractionCard fraction={f} text={t.fractions[f.id]} ui={ui} />
      ))
    }
  </div>

  <footer class="guide__foot">
    <p class="guide__legal">{ui.legalNote}</p>
    <p class="guide__sources">
      <strong>{ui.sourcesTitle}:</strong>
      <a
        href="https://sortere.no/"
        target="_blank"
        rel="noopener noreferrer"
        lang="nb"
        aria-describedby="newtab-note">sortere.no</a
      > · <span>{ui.lastVerified}: <span lang="nb">{verified}</span></span>
    </p>
    <span id="newtab-note" class="sr-only">{ui.opensInNewTab}</span>
  </footer>
</div>
