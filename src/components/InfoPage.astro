---
import LanguagePicker from '../components/LanguagePicker.astro';
import { localeHome } from '../i18n/paths';
import { getStrings, type PageKey } from '../i18n/strings';
import BaseLayout from '../layouts/BaseLayout.astro';

// Спільний шаблон інфосторінок центру (about/rules/guide): заголовок, лід
// і блоки. Блок без body рендериться як чесна плашка «згодом буде».
// body — може бути HTML (збережений раніше) або plain text (Pages CMS TipTap
// зберігає як plain text з "- " маркерами та "\n\n" між абзацами).
// bodyToHtml() нормалізує обидва формати до HTML для рендерингу.
function bodyToHtml(body: string): string {
  if (!body.trim()) return '';
  const esc = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const lines = body.split('\n');
  const out: string[] = [];
  let listItems: string[] = [];
  const flushList = () => {
    if (listItems.length) {
      out.push(
        '<ul>' + listItems.map((li) => `<li>${li}</li>`).join('') + '</ul>',
      );
      listItems = [];
    }
  };
  for (const line of lines) {
    const stripped = line.trim();
    if (!stripped) {
      flushList();
      continue;
    }
    if (stripped.startsWith('- ') || stripped.startsWith('• ')) {
      listItems.push(esc(stripped.slice(2).trim()));
    } else {
      flushList();
      out.push(`<p>${esc(stripped)}</p>`);
    }
  }
  flushList();
  return out.join('');
}

interface Props {
  locale: string;
  pageKey: PageKey;
}

const { locale, pageKey } = Astro.props;
const t = getStrings(locale);
const site = t.site;
const page = t.pages[pageKey];
---

<BaseLayout
  locale={locale}
  title={`${page.title} · ${site.name}`}
  description={page.lead}
>
  <a class="skip-link" href="#main">{t.ui.skipToContent}</a>

  <header class="site-header">
    <div class="wrap site-header__bar site-header__bar--quiz">
      <div class="brand">
        <a class="brand__mark brand__link" href={localeHome(locale)}
          >{site.name}</a
        >
      </div>
      <div class="site-header__tools">
        <LanguagePicker current={locale} label={t.ui.languagePicker} />
      </div>
    </div>
  </header>

  <main id="main" class="wrap info-page" data-page={pageKey}>
    <header class="info-page__head">
      <h1 class="page-title">{page.title}</h1>
      <p class="lede">{page.lead}</p>
    </header>

    {
      page.blocks.map((block) => (
        <section class="info-block">
          <h2 class="info-block__heading">{block.heading}</h2>
          {block.body ? (
            <div class="info-block__content" set:html={bodyToHtml(block.body)} />
          ) : (
            <p class="info-block__soon">{site.comingSoon}</p>
          )}
        </section>
      ))
    }
    <slot />
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>{site.name} · {site.tagline}</p>
    </div>
  </footer>
</BaseLayout>
